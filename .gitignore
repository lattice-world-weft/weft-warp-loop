build/
build_local/
flow-toolchain/vcpkg_installed/
__pycache__/
# picoquic_fanout_server / s7_riscv_actor_test / fanout_load_client write flow trace logs into their cwd
fanout_server.*.xml
s7_riscv_actor_test.*.xml
fanout_load_client.*.xml
fanout_load_client_worker.*.xml
fanout_load_client_multi.*.xml
/flow-toolchain/sketch-core/.lake/
# IrCodegenScratch.lean's intermediates (regenerated every run) - the
# linked .elf it produces IS committed, matching s7_guest.elf's own
# precedent of being a checked-in artifact, not a build output.
/flow-toolchain/fanout-core/IrCodegenScratch_out.s
/flow-toolchain/fanout-core/IrCodegenScratch_out.o

# riscv-guests/README.md's own build recipe's intermediates (regenerated
# every rebuild) - only the final linked s7_guest.elf is committed.
/flow-toolchain/riscv-guests/mus-config.h
/flow-toolchain/riscv-guests/s7.o
/flow-toolchain/riscv-guests/s7_guest_main.o

# General build/toolchain intermediates that can appear anywhere a
# scratch script or manual toolchain invocation runs, not just the
# specific paths above.
*.o
*.obj
*.olean
*.ilean
.lake/
*.log
*.tmp