(define (alist-set al key val) (cond ((null? al) (list (cons key val))) ((equal? (car (car al)) key) (cons (cons key val) (cdr al))) (else (cons (car al) (alist-set (cdr al) key val)))))
(define (apply-effects state effects) (cond ((null? effects) state) (else (apply-effects (alist-set state (car (car effects)) (cdr (car effects))) (cdr effects)))))
(define (run-action state name actions) (let* ((body (cdr (assoc name actions)))) (apply-effects state body)))
(define (try-alternatives state todo alts actions methods) (cond ((null? alts) #f) (else (let* ((subtasks (cdr (car alts)))) (let* ((result (find-plan state (append subtasks todo) actions methods))) (cond (result result) (else (try-alternatives state todo (cdr alts) actions methods))))))))
(define (find-plan state todo actions methods) (cond ((null? todo) (list state '())) (else (let* ((task (car todo)) (rest (cdr todo)) (name (car task))) (cond ((assoc name actions) (let* ((new-state (run-action state name actions))) (let* ((sub (find-plan new-state rest actions methods))) (cond (sub (list (car sub) (cons name (car (cdr sub))))) (else #f))))) ((assoc name methods) (try-alternatives state rest (cdr (assoc name methods)) actions methods)) (else #f))))))
