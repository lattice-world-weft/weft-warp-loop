{
  "@context": { "vsekai": "https://v-sekai.org/", "domain": "vsekai:planning/domain/" },
  "@type": "domain:Definition",
  "name": "weft_warp_loop_bootstrap",
  "variables": [
    { "name": "milestone", "type": "ref", "init": { "stack": "bare_boot" } }
  ],
  "actions": {
    "setup_flow_toolchain": {
      "params": [],
      "body": [{ "pointer/set": "/milestone/stack", "value": "flow_toolchain_ready" }]
    },
    "prove_http3_roundtrip": {
      "params": [],
      "body": [{ "pointer/set": "/milestone/stack", "value": "http3_roundtrip" }]
    },
    "add_tick_loop": {
      "params": [],
      "body": [{ "pointer/set": "/milestone/stack", "value": "tick_loop" }]
    },
    "add_input_path": {
      "params": [],
      "body": [{ "pointer/set": "/milestone/stack", "value": "input_path" }]
    },
    "add_state_sync": {
      "params": [],
      "body": [{ "pointer/set": "/milestone/stack", "value": "playing_loop" }]
    }
  },
  "methods": {
    "bootstrap": {
      "params": [],
      "alternatives": [
        {
          "name": "sequential_increments",
          "subtasks": [
            ["setup_flow_toolchain"],
            ["prove_http3_roundtrip"],
            ["add_tick_loop"],
            ["add_input_path"],
            ["add_state_sync"]
